# Copy this file to `.env` and fill in your key.
# .env is gitignored and never committed.

# Required to turn on LLM-backed agent reasoning.
# When unset, every agent falls back to deterministic rules and the dashboard
# still works exactly like SCF Marvel.
OPENAI_API_KEY=

# Optional: override the default LLM model.
# Defaults to OpenAI's latest flagship reasoning-friendly GPT-4 class model.
WONDER_LLM_MODEL=gpt-4o-2024-11-20

# Optional: low temperature keeps decisions consistent for underwriting.
WONDER_LLM_TEMPERATURE=0.1

# Optional: override the on-disk SQLite path.
# WONDER_DB_URL=sqlite:///data/wonder.db

# Optional: override the platform base rate (decimal form; 0.02 == 2%).
# WONDER_BASE_RATE=0.02
